# Azure Whisper (speech-to-text)
WHISPER_KEY=your_azure_cognitive_services_key
# WHISPER_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/deployments/whisper/audio/transcriptions?api-version=2024-06-01

# Azure / Anthropic chat
AZURE_CHAT_KEY=your_azure_ai_services_key
